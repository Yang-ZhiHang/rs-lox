// Recursive Fibonacci
fun fib(n) {
  if (n <= 1) return n;
  return fib(n - 1) + fib(n - 2);
}

// Iterative Fibonacci
fun fibIter(n) {
  if (n <= 1) return n;

  let a = 0;
  let b = 1;

  for (let i = 2; i <= n; i = i + 1) {
    let temp = b;
    b = a + b;
    a = temp;
  }
  return b;
}

println("Fibonacci Recursive (10): " + fib(10)); // 55
println("Fibonacci Iterative (20): " + fibIter(20)); // 6765
